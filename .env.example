# === AniBT-Speed Configuration ===
# Only minimal secrets here. All other config (qBT instances,
# Telegram, policies) is managed via the Web UI.

SECRET_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=your-admin-password

# CORS allowed origins (comma-separated). Leave empty for same-origin only.
# Example: CORS_ORIGINS=http://localhost:6868,https://my-domain.com
CORS_ORIGINS=
